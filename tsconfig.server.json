{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "out/server",
    "rootDir": "src",
    "sourceMap": true
  },
  "include": ["src/server/**/*.ts", "src/shared/**/*.ts"]
}
